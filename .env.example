# ============================================
# VideoForge — Environment Variables
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/videoforge"

# ── Authentication (NextAuth) ──
NEXTAUTH_URL="http://localhost:3100"
NEXTAUTH_SECRET="change-me-to-a-random-string"

# ── DeepSeek API (文本分析 / 评估) ──
# 通过 Anthropic 兼容接口调用 DeepSeek 模型
DEEPSEEK_BASE_URL="https://api.deepseek.com/anthropic"
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"
DEEPSEEK_MODEL="deepseek-v4-pro"

# ── 灵客 API (GPT / Gemini / 图片/视频生成) ──
LINGKE_API_BASE_URL="https://api.lk888.ai/v1"
LINGKE_API_KEY="sk-your-lingke-api-key"

# ── Optional: 自定义端口 ──
# PORT=3100
